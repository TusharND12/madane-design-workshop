# Copy to .env.local and fill in. None are required for local development.

# Canonical site origin used for metadata, sitemap, robots and JSON-LD.
# Defaults to https://madane.in if unset (see src/content/site.ts).
NEXT_PUBLIC_SITE_URL=https://madane.in

# Where validated enquiries are forwarded (email/WhatsApp/CRM webhook).
# If unset, leads are written to the server log instead (see src/app/api/enquiry/route.ts).
ENQUIRY_WEBHOOK_URL=
